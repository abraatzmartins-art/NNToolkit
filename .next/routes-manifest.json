      "page": "/api/apify/results/[runId]",
      "regex": "^/api/apify/results/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPrunId": "nxtPrunId"
      },
      "namedRegex": "^/api/apify/results/(?<nxtPrunId>[^/]+?)(?:/)?$"
    },
    {
